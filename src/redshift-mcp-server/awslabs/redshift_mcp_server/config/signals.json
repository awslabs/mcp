{
  "ATOWorkerActions": {
    "Signals": [
      {
        "Criteria": "alter_table_type='encode'",
        "PopulationCriteria": "trim(status) != 'Abort:This table is already the recommended style.' and trim(status) != 'Complete: 100%'",
        "Recommendation": [
          "REC-004"
        ],
        "Signal": "column encoding on table is not set to auto"
      },
      {
        "Criteria": "alter_table_type='distkey'",
        "PopulationCriteria": "trim(status) != 'Abort:This table is already the recommended style.' and trim(status) != 'Complete: 100%'",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "distribution style on table is not set to auto"
      },
      {
        "Criteria": "alter_table_type='sortkey'",
        "PopulationCriteria": "trim(status) != 'Abort:This table is already the recommended style.' and trim(status) != 'Complete: 100%'",
        "Recommendation": [
          "REC-007"
        ],
        "Signal": "sort key on table is not set to auto"
      }
    ]
  },
  "AlterTableRecommendations": {
    "Signals": [
      {
        "Criteria": "type='encode' and auto_eligible='f'",
        "Recommendation": [
          "REC-004"
        ],
        "Signal": "column encoding recommendation on table is not automatically applied"
      },
      {
        "Criteria": "type='sortkey' and auto_eligible='f'",
        "Recommendation": [
          "REC-007"
        ],
        "Signal": "sort key recommendation on table is not automatically applied"
      },
      {
        "Criteria": "type='diststyle' and auto_eligible='f'",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "dist key recommendation on table is not automatically applied"
      }
    ]
  },
  "CopyPerformance": {
    "Signals": [
      {
        "Criteria": "avg_files_per_copy < 64",
        "PopulationCriteria": "no_of_copy > 24",
        "Recommendation": [
          "REC-023"
        ],
        "Signal": "files per copy are less than slice count"
      },
      {
        "Criteria": "avg_file_size_mb < 10",
        "PopulationCriteria": "no_of_copy > 24",
        "Recommendation": [
          "REC-023"
        ],
        "Signal": "files with a small size"
      }
    ]
  },
  "DataShareConsumerUsage": {
    "Signals": [
      {
        "Criteria": "avg_request_duration_secs > 60",
        "Recommendation": [
          "REC-028",
          "REC-034"
        ],
        "Signal": "long running metadata sync"
      }
    ]
  },
  "DataShareProducerObject": {
    "Signals": [
      {
        "Criteria": "is_mv_incremental_refresh = 'N'",
        "Recommendation": [
          "REC-034"
        ],
        "Signal": "materialized view shared by a producer is doing a full refresh"
      }
    ]
  },
  "ExtQueryPerformance": {
    "Signals": [
      {
        "Criteria": "pct_of_query_using_partition_pruning < 95",
        "PopulationCriteria": "avg_qualified_partitions > 100 and avg_elapsed_sec > 60",
        "Recommendation": [
          "REC-027"
        ],
        "Signal": "high count of long queries not using partition pruning"
      }
    ]
  },
  "MaterializedView": {
    "Signals": [
      {
        "Criteria": "state=0",
        "Recommendation": [
          "REC-030"
        ],
        "Signal": "materialized view is doing a full refresh"
      },
      {
        "Criteria": "state > 1 and is_stale = 't' and autorefresh = 'y'",
        "Recommendation": [
          "REC-031"
        ],
        "Signal": "materialized view cannot be auto refreshed"
      },
      {
        "Criteria": "is_stale = 't'",
        "Recommendation": [
          "REC-039"
        ],
        "Signal": "materialized view is stale"
      }
    ]
  },
  "NodeDetails": {
    "Signals": [
      {
        "Criteria": "storage_utilization_pct > 70 and (node_type like 'dc%' or node_type like 'ds%')",
        "Recommendation": [
          "REC-001",
          "REC-002",
          "REC-004",
          "REC-005",
          "REC-006"
        ],
        "Signal": "exceeds the recommended storage threshold of 70%"
      },
      {
        "Criteria": "storage_utilization_pct < 40 and not node_type like 'ra3%'",
        "Recommendation": [
          "REC-012"
        ],
        "Signal": "has under-utilized storage"
      },
      {
        "Criteria": "100*abs(storage_used_gb - (select min(storage_used_gb) from NodeDetails))/storage_used_gb >= 10",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "has 10% data skew"
      },
      {
        "Criteria": "node_type like 'dc1%' or node_type like 'ds2%'",
        "Recommendation": [
          "REC-001"
        ],
        "Signal": "are using a legacy node type"
      }
    ]
  },
  "TableInfo": {
    "Signals": [
      {
        "Criteria": "max_varchar > 1000",
        "Recommendation": [
          "REC-011"
        ],
        "Signal": "tables with wide columns"
      },
      {
        "Criteria": "sortkey1 = ''",
        "PopulationCriteria": "tbl_rows > 5000000 and sortkey1 != 'AUTO(SORTKEY%'",
        "Recommendation": [
          "REC-007"
        ],
        "Signal": "large tables without a sort key"
      },
      {
        "Criteria": "skew_rows >= 4 and diststyle not like 'AUTO%'",
        "PopulationCriteria": "tbl_rows > 5000000",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "large tables with skew"
      },
      {
        "Criteria": "vacuum_sort_benefit >= 10",
        "PopulationCriteria": "tbl_rows > 5000000",
        "Recommendation": [
          "REC-013"
        ],
        "Signal": "large tables with unsorted data"
      },
      {
        "Criteria": "sortkey1 like '%INTERLEAVED%'",
        "PopulationCriteria": "tbl_rows > 5000000",
        "Recommendation": [
          "REC-014"
        ],
        "Signal": "tables with interleaved sort keys"
      },
      {
        "Criteria": "diststyle not like '%ALL%'",
        "PopulationCriteria": "tbl_rows <= 5000000 and diststyle not like 'AUTO%'",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "small tables without an ALL distribution"
      },
      {
        "Criteria": "sortkey1 != ''",
        "PopulationCriteria": "tbl_rows <= 5000000 and sortkey1 not like 'AUTO(SORTKEY%'",
        "Recommendation": [
          "REC-007"
        ],
        "Signal": "small tables with a sort key"
      },
      {
        "Criteria": "pct_rows_marked_for_deletion > 10",
        "PopulationCriteria": "tbl_rows > 5000000",
        "Recommendation": [
          "REC-002"
        ],
        "Signal": "large tables needing a vacuum delete"
      },
      {
        "Criteria": "stats_off > 10 or stats_off is null",
        "Recommendation": [
          "REC-003"
        ],
        "Signal": "tables with out of date statistics"
      },
      {
        "Criteria": "sortkey1_enc != 'none' and sortkey1_enc != ''",
        "PopulationCriteria": "tbl_rows > 5000000 and not sortkey1 like 'AUTO(SORTKEY%'",
        "Recommendation": [
          "REC-010"
        ],
        "Signal": "large tables with encoded sort keys"
      },
      {
        "Criteria": "encoded_column_pct < 80",
        "PopulationCriteria": "((column_count - encoded_column_count) - (case when sortkey1_enc = 'none' or sortkey1_enc = '' then 1 else 0 end)) AND tbl_rows > 5000000",
        "Recommendation": [
          "REC-004"
        ],
        "Signal": "tables with low column compression"
      },
      {
        "Criteria": "diststyle like '%KEY%date%' or diststyle like '%KEY%dt%' or diststyle like '%KEY%timestamp%' or diststyle like '%KEY%datetime%'",
        "PopulationCriteria": "tbl_rows > 5000000",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "large tables distributed by date or datetime"
      }
    ]
  },
  "Top50QueriesByRunTime": {
    "Signals": [
      {
        "Criteria": "lower(alerts) like '%stat%'",
        "Recommendation": [
          "REC-003"
        ],
        "Signal": "long running queries with missing Table Statistics"
      },
      {
        "Criteria": "lower(alerts) like '%nl%'",
        "Recommendation": [
          "REC-009",
          "REC-022"
        ],
        "Signal": "long running queries using Nested Loop Joins"
      },
      {
        "Criteria": "lower(alerts) like '%dist%' or lower(alerts) like '%broadcast%'",
        "Recommendation": [
          "REC-008"
        ],
        "Signal": "long running queries with Dist or Broadcast alerts"
      },
      {
        "Criteria": "lower(alerts) like '%sort%'",
        "Recommendation": [
          "REC-007"
        ],
        "Signal": "long running queries with Sort alerts"
      },
      {
        "Criteria": "total_disk_spill_mb > 100",
        "Recommendation": [
          "REC-005",
          "REC-011",
          "REC-022",
          "REC-024"
        ],
        "Signal": "high count of queries with large disk spill"
      }
    ]
  },
  "UsagePattern": {
    "Signals": [
      {
        "Criteria": "copy_count > 100",
        "Recommendation": [
          "REC-023"
        ],
        "Signal": "high count of COPY command"
      },
      {
        "Criteria": "small_insert_count > 100",
        "Recommendation": [
          "REC-029"
        ],
        "Signal": "high count of small_insert statements"
      },
      {
        "Criteria": "ddl_count > 10",
        "Recommendation": [
          "REC-025"
        ],
        "Signal": "high count of DDL command"
      },
      {
        "Criteria": "ctas_count > 10",
        "Recommendation": [
          "REC-025"
        ],
        "Signal": "high count of CTAS command"
      },
      {
        "Criteria": "pct_wlm_queue_time > 5",
        "Recommendation": [
          "REC-019",
          "REC-020",
          "REC-026"
        ],
        "Signal": "high count of WLM queuing"
      },
      {
        "Criteria": "total_disk_spill_count > 10",
        "Recommendation": [
          "REC-005",
          "REC-011",
          "REC-022",
          "REC-024"
        ],
        "Signal": "high count of spilled to disk"
      },
      {
        "Criteria": "compiled_queries > 100",
        "Recommendation": [
          "REC-025"
        ],
        "Signal": "high count of compiled"
      },
      {
        "Criteria": "burst_secs > 600",
        "Recommendation": [
          "REC-033"
        ],
        "Signal": "high concurrency scaling usage"
      }
    ]
  },
  "WLMConfig": {
    "Signals": [
      {
        "Criteria": "(select sum(cluster_memory_pct) from WLMConfig) < 100",
        "PopulationCriteria": "wlm_mode='manual' and service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-016"
        ],
        "Signal": "queues do not have total memory = 100"
      },
      {
        "Criteria": "(select sum(slots) from WLMConfig where service_class_id not in (5,14,15)) > 20",
        "PopulationCriteria": "wlm_mode='manual' and service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-017"
        ],
        "Signal": "queues have total concurrency > 20"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where service_class_category = 'Manual WLM') = 1 OR (select count(1) from WLMConfig where service_class_category = 'Auto WLM') = 1",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-018"
        ],
        "Signal": "uses single WLM queue"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where wlm_mode='manual') > 0",
        "PopulationCriteria": "wlm_mode='manual' and service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-015"
        ],
        "Signal": "uses manual WLM"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where concurrency_scaling = 'auto') = 0",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-019"
        ],
        "Signal": "Concurrency scaling is not enabled"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where service_class_category != 'SQA') = (select count(1) from WLMConfig)",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 15",
        "Recommendation": [
          "REC-020"
        ],
        "Signal": "short query acceleration (SQA) is not enabled"
      },
      {
        "Criteria": "(select count(distinct queue_priority) from WLMConfig) = 1",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-021"
        ],
        "Signal": "all query queues having the same query priority"
      },
      {
        "Criteria": "(select sum(qmr_rule_count) from WLMConfig) = 0",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-022"
        ],
        "Signal": "no query monitoring rules (QMR) defined"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where coalesce(qmr_rule,'') not like '%query_execution_time%') = (select count(1) from WLMConfig)",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-022"
        ],
        "Signal": "no QMR defined for query_execution_time metric"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where coalesce(qmr_rule,'') not like '%query_temp_blocks_to_disk%') = (select count(1) from WLMConfig)",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-022"
        ],
        "Signal": "no QMR defined for query_temp_blocks_to_disk metric"
      },
      {
        "Criteria": "(select count(1) from WLMConfig where coalesce(qmr_rule,'') not like '%spectrum_scan%') = (select count(1) from WLMConfig)",
        "PopulationCriteria": "service_class_id <> 5 and service_class_id <> 14 and service_class_id <> 15",
        "Recommendation": [
          "REC-022"
        ],
        "Signal": "no QMR defined for spectrum_scan_size_mb or spectrum_scan_row_count metric"
      }
    ]
  },
  "WorkloadEvaluation": {
    "Signals": [
      {
        "Criteria": "total_pct_busy < 75",
        "Recommendation": [
          "REC-035"
        ],
        "Signal": "Evaluate Workload for Serverless. Cluster is busy less than 75% of the time in a day."
      }
    ]
  }
}
