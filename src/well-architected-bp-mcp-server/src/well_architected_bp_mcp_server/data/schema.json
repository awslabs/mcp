{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "items": {
    "additionalProperties": false,
    "properties": {
      "anti_patterns": {
        "description": "Common anti-patterns to avoid (lens data only)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "area": {
        "items": {
          "type": "string"
        },
        "minItems": 1,
        "type": "array"
      },
      "benefits": {
        "description": "Benefits of establishing this best practice (lens data only)",
        "oneOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        ]
      },
      "description": {
        "minLength": 1,
        "type": "string"
      },
      "desired_outcome": {
        "description": "Concrete outcomes that indicate this best practice is established (lens data only)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "href": {
        "format": "uri",
        "type": "string"
      },
      "id": {
        "pattern": "^[A-Z]{3,10}\\d{2}-BP\\d{2}$",
        "type": "string"
      },
      "implementation_guidance": {
        "description": "Actionable steps to implement this best practice (lens data only)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "lens": {
        "default": "FRAMEWORK",
        "type": "string"
      },
      "pillar": {
        "enum": [
          "OPERATIONAL_EXCELLENCE",
          "SECURITY",
          "RELIABILITY",
          "PERFORMANCE_EFFICIENCY",
          "COST_OPTIMIZATION",
          "SUSTAINABILITY"
        ],
        "type": "string"
      },
      "relatedIds": {
        "items": {
          "pattern": "^[A-Z]{3,10}\\d{1,3}(-BP\\d{2})?$",
          "type": "string"
        },
        "type": "array"
      },
      "resources": {
        "description": "Related best practices, documents, and AWS services (lens data only)",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "risk": {
        "enum": [
          "HIGH",
          "MEDIUM",
          "LOW"
        ],
        "type": "string"
      },
      "title": {
        "minLength": 1,
        "type": "string"
      },
      "title_full": {
        "minLength": 1,
        "type": "string"
      }
    },
    "required": [
      "id",
      "title_full",
      "title",
      "href",
      "description",
      "pillar",
      "area",
      "relatedIds",
      "risk"
    ],
    "type": "object"
  },
  "type": "array"
}
