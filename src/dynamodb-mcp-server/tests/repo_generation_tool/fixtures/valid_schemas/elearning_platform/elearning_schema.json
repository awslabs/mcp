          "sk_template": "COURSE#DETAILS",
          "fields": [
            { "name": "tenant_id", "type": "string", "required": true },
            { "name": "course_id", "type": "string", "required": true },
            { "name": "title", "type": "string", "required": true },
            { "name": "description", "type": "string", "required": true },
            { "name": "instructor_id", "type": "string", "required": true },
            { "name": "instructor_name", "type": "string", "required": true },
            { "name": "category", "type": "string", "required": true },
            { "name": "difficulty_level", "type": "string", "required": true },
            { "name": "duration_hours", "type": "integer", "required": true },
            { "name": "max_enrollments", "type": "integer", "required": false },
            { "name": "prerequisites", "type": "array", "item_type": "string", "required": false },
