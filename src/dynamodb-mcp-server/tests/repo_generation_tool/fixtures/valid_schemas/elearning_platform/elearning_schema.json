{
  "tables": [
    {
      "table_config": {
        "table_name": "ELearningPlatform",
        "partition_key": "pk",
        "sort_key": "sk"
      },
      "entities": {
        "TenantOrganization": {
          "entity_type": "ORG",
          "pk_template": "TENANT#{tenant_id}",
          "sk_template": "ORG#PROFILE",
          "fields": [
            { "name": "tenant_id", "type": "string", "required": true },
            { "name": "organization_name", "type": "string", "required": true },
            { "name": "domain", "type": "string", "required": true },
            { "name": "subscription_plan", "type": "string", "required": true },
            { "name": "max_users", "type": "integer", "required": true },
            { "name": "max_courses", "type": "integer", "required": true },
            { "name": "admin_email", "type": "string", "required": true },
            { "name": "created_at", "type": "integer", "required": true },
            { "name": "status", "type": "string", "required": true }
          ],
          "access_patterns": [
            {
              "pattern_id": 1,
              "name": "get_tenant_organization",
              "description": "Get organization details for a tenant",
              "operation": "GetItem",
              "parameters": [{ "name": "tenant_id", "type": "string" }],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 2,
              "name": "create_tenant_organization",
              "description": "Create new tenant organization",
              "operation": "PutItem",
              "parameters": [{ "name": "organization", "type": "entity", "entity_type": "TenantOrganization" }],
              "return_type": "single_entity"
            }
          ]
        },
        "TenantUser": {
          "entity_type": "USER",
          "pk_template": "TENANT#{tenant_id}#USER#{user_id}",
          "sk_template": "USER#PROFILE",
          "fields": [
            { "name": "tenant_id", "type": "string", "required": true },
            { "name": "user_id", "type": "string", "required": true },
            { "name": "email", "type": "string", "required": true },
            { "name": "first_name", "type": "string", "required": true },
            { "name": "last_name", "type": "string", "required": true },
            { "name": "role", "type": "string", "required": true },
            { "name": "department", "type": "string", "required": false },
            { "name": "job_title", "type": "string", "required": false },
            { "name": "enrollment_date", "type": "integer", "required": true },
            { "name": "last_login", "type": "integer", "required": false },
            { "name": "status", "type": "string", "required": true }
          ],
          "access_patterns": [
            {
              "pattern_id": 3,
              "name": "get_tenant_user",
              "description": "Get user profile within tenant",
              "operation": "GetItem",
              "parameters": [
                { "name": "tenant_id", "type": "string" },
                { "name": "user_id", "type": "string" }
              ],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 4,
              "name": "create_tenant_user",
              "description": "Create new user in tenant",
              "operation": "PutItem",
              "parameters": [{ "name": "user", "type": "entity", "entity_type": "TenantUser" }],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 5,
              "name": "update_user_profile",
              "description": "Update user profile information",
              "operation": "UpdateItem",
              "parameters": [
                { "name": "tenant_id", "type": "string" },
                { "name": "user_id", "type": "string" },
                { "name": "updates", "type": "entity", "entity_type": "TenantUser" }
              ],
              "return_type": "single_entity"
            }
          ]
        },
