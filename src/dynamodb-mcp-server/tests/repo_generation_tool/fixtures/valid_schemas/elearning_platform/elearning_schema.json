              "description": "Get course details within tenant",
              "operation": "GetItem",
              "parameters": [
                { "name": "tenant_id", "type": "string" },
                { "name": "course_id", "type": "string" }
              ],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 7,
              "name": "create_tenant_course",
              "description": "Create new course in tenant",
              "operation": "PutItem",
              "parameters": [{ "name": "course", "type": "entity", "entity_type": "TenantCourse" }],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 8,
              "name": "update_course_details",
              "description": "Update course information",
              "operation": "UpdateItem",
              "parameters": [
                { "name": "tenant_id", "type": "string" },
                { "name": "course_id", "type": "string" },
                { "name": "updates", "type": "entity", "entity_type": "TenantCourse" }
              ],
              "return_type": "single_entity"
            }
          ]
        },
