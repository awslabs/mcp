              "operation": "UpdateItem",
              "parameters": [
                { "name": "tenant_id", "type": "string" },
                { "name": "user_id", "type": "string" },
                { "name": "course_id", "type": "string" },
                { "name": "lesson_id", "type": "string" },
                { "name": "attempt_date", "type": "integer" },
