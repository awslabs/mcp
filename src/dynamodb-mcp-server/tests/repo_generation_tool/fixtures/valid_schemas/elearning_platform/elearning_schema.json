            {
              "pattern_id": 10,
              "name": "enroll_user_in_course",
              "description": "Enroll user in a course",
              "operation": "PutItem",
              "parameters": [{ "name": "enrollment", "type": "entity", "entity_type": "TenantEnrollment" }],
              "return_type": "single_entity"
