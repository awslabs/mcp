            { "name": "appointment_id", "type": "string", "required": true },
            { "name": "patient_id", "type": "string", "required": true },
            { "name": "provider_id", "type": "string", "required": true },
            { "name": "appointment_date", "type": "string", "required": true },
            { "name": "appointment_time", "type": "string", "required": true },
            { "name": "duration_minutes", "type": "integer", "required": true },
            { "name": "appointment_type", "type": "string", "required": true },
            { "name": "reason", "type": "string", "required": true },
            { "name": "status", "type": "string", "required": true },
            { "name": "location", "type": "string", "required": true },
            { "name": "notes", "type": "string", "required": false },
            { "name": "insurance_authorization", "type": "string", "required": false },
            { "name": "copay_amount", "type": "decimal", "required": false },
            { "name": "created_at", "type": "string", "required": true },
            { "name": "updated_at", "type": "string", "required": true },
            { "name": "checked_in_at", "type": "string", "required": false },
            { "name": "completed_at", "type": "string", "required": false }
