              "operation": "Query",
              "parameters": [
                { "name": "provider_id", "type": "string" },
                { "name": "date", "type": "string" }
              ],
              "return_type": "entity_list"
            }
          ]
        }
      }
    },
    {
      "table_config": {
        "table_name": "AppointmentTable",
        "partition_key": "pk",
        "sort_key": "sk"
      },
      "entities": {
