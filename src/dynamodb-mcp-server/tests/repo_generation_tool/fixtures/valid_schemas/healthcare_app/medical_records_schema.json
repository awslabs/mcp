            { "name": "updated_at", "type": "string", "required": true },
            { "name": "status", "type": "string", "required": true }
          ],
          "access_patterns": [
            {
              "pattern_id": 9,
              "name": "get_provider",
              "description": "Get provider profile by ID",
              "operation": "GetItem",
              "parameters": [{ "name": "provider_id", "type": "string" }],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 10,
