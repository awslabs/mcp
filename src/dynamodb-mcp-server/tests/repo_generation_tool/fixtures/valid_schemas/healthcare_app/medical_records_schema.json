              "operation": "Query",
              "parameters": [
                { "name": "provider_id", "type": "string" },
                { "name": "start_date", "type": "string" },
                { "name": "end_date", "type": "string" }
              ],
              "return_type": "entity_list"
            },
            {
              "pattern_id": 15,
              "name": "get_available_slots",
