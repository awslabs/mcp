{
  "tables": [
    {
      "table_config": {
        "table_name": "PatientTable",
        "partition_key": "pk",
        "sort_key": "sk"
      },
      "entities": {
        "Patient": {
          "entity_type": "PATIENT",
          "pk_template": "PATIENT#{patient_id}",
          "sk_template": "PROFILE",
          "fields": [
            { "name": "patient_id", "type": "string", "required": true },
            { "name": "medical_record_number", "type": "string", "required": true },
            { "name": "first_name", "type": "string", "required": true },
            { "name": "last_name", "type": "string", "required": true },
            { "name": "date_of_birth", "type": "string", "required": true },
            { "name": "gender", "type": "string", "required": true },
            { "name": "phone", "type": "string", "required": true },
            { "name": "email", "type": "string", "required": false },
            { "name": "address", "type": "object", "required": true },
            { "name": "emergency_contact", "type": "object", "required": true },
            { "name": "insurance_info", "type": "object", "required": false },
            { "name": "primary_care_provider_id", "type": "string", "required": false },
            { "name": "created_at", "type": "string", "required": true },
            { "name": "updated_at", "type": "string", "required": true },
            { "name": "status", "type": "string", "required": true }
          ],
          "access_patterns": [
            {
              "pattern_id": 1,
              "name": "get_patient",
              "description": "Get patient profile by ID",
              "operation": "GetItem",
              "parameters": [{ "name": "patient_id", "type": "string" }],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 2,
              "name": "create_patient",
              "description": "Create new patient record",
              "operation": "PutItem",
              "parameters": [{ "name": "patient", "type": "entity", "entity_type": "Patient" }],
              "return_type": "single_entity"
            },
            {
              "pattern_id": 3,
              "name": "update_patient_info",
              "description": "Update patient contact and insurance information",
              "operation": "UpdateItem",
              "parameters": [
                { "name": "patient_id", "type": "string" },
                { "name": "updates", "type": "entity", "entity_type": "Patient" }
              ],
              "return_type": "single_entity"
            }
          ]
        },
        "PatientMedicalHistory": {
          "entity_type": "MEDICAL_HISTORY",
          "pk_template": "PATIENT#{patient_id}",
          "sk_template": "HISTORY#{record_date}#{record_id}",
          "fields": [
            { "name": "patient_id", "type": "string", "required": true },
            { "name": "record_id", "type": "string", "required": true },
            { "name": "record_date", "type": "string", "required": true },
            { "name": "record_type", "type": "string", "required": true },
            { "name": "provider_id", "type": "string", "required": true },
            { "name": "diagnosis_codes", "type": "array", "item_type": "string", "required": false },
            { "name": "procedure_codes", "type": "array", "item_type": "string", "required": false },
            { "name": "medications", "type": "array", "item_type": "string", "required": false },
            { "name": "allergies", "type": "array", "item_type": "string", "required": false },
            { "name": "vital_signs", "type": "object", "required": false },
            { "name": "notes", "type": "string", "required": false },
            { "name": "attachments", "type": "array", "item_type": "string", "required": false },
            { "name": "created_at", "type": "string", "required": true }
          ],
          "access_patterns": [
            {
              "pattern_id": 4,
              "name": "get_patient_medical_history",
              "description": "Get medical history for patient (sorted by date)",
              "operation": "Query",
              "parameters": [{ "name": "patient_id", "type": "string" }],
              "return_type": "entity_list"
            },
            {
              "pattern_id": 5,
              "name": "get_patient_history_by_date_range",
              "description": "Get patient medical history within date range",
              "operation": "Query",
              "parameters": [
                { "name": "patient_id", "type": "string" },
                { "name": "start_date", "type": "string" },
                { "name": "end_date", "type": "string" }
              ],
              "return_type": "entity_list"
            },
            {
              "pattern_id": 6,
              "name": "add_medical_record",
              "description": "Add medical record with provider reference",
              "operation": "PutItem",
              "parameters": [
                { "name": "medical_record", "type": "entity", "entity_type": "PatientMedicalHistory" },
                { "name": "provider_id", "type": "string" }
              ],
              "return_type": "single_entity"
            }
          ]
        },
        "PatientAllergy": {
          "entity_type": "ALLERGY",
          "pk_template": "PATIENT#{patient_id}",
          "sk_template": "ALLERGY#{allergy_id}",
          "fields": [
            { "name": "patient_id", "type": "string", "required": true },
            { "name": "allergy_id", "type": "string", "required": true },
            { "name": "allergen", "type": "string", "required": true },
            { "name": "allergy_type", "type": "string", "required": true },
            { "name": "severity", "type": "string", "required": true },
            { "name": "reaction", "type": "string", "required": false },
            { "name": "onset_date", "type": "string", "required": false },
            { "name": "notes", "type": "string", "required": false },
            { "name": "status", "type": "string", "required": true },
            { "name": "created_at", "type": "string", "required": true }
          ],
          "access_patterns": [
            {
              "pattern_id": 7,
              "name": "get_patient_allergies",
              "description": "Get all active allergies for patient",
              "operation": "Query",
              "parameters": [{ "name": "patient_id", "type": "string" }],
              "return_type": "entity_list"
            },
            {
              "pattern_id": 8,
              "name": "add_patient_allergy",
              "description": "Add allergy record for patient",
              "operation": "PutItem",
              "parameters": [{ "name": "allergy", "type": "entity", "entity_type": "PatientAllergy" }],
              "return_type": "single_entity"
            }
          ]
        }
      }
    },
    {
      "table_config": {
        "table_name": "ProviderTable",
        "partition_key": "pk",
        "sort_key": "sk"
      },
      "entities": {
