#
# Convenience wrapper so `./poe <task>` works from the repo root without
# having to cd into the package. Forwards to uv run poe scoped to this
# package's pyproject.toml.
#
# Tasks are declared under [tool.poe.tasks] in
# src/cloudwatch-applicationsignals-mcp-server/pyproject.toml.
# Run `./poe` (no args) from repo root to list them.

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  target="$(readlink "$SOURCE")"
  if [[ "$target" = /* ]]; then
    SOURCE="$target"
  else
    SOURCE="$(cd -- "$(dirname -- "$SOURCE")" &>/dev/null && pwd)/$target"
  fi
done
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE")" &>/dev/null && pwd)"
exec uv --directory "$SCRIPT_DIR" run poe "$@"
